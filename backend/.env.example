# =============================================================
# miniLab1 — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# =============================================================

# Servidor
PORT=3001

# Google Gemini (usado pelo Image Analyzer e Campaign Generator)
# Obtenha sua chave gratuita em: https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Temperatura dos agentes (0.0 = determinístico, 1.0 = criativo)
IMAGE_ANALYZER_TEMPERATURE=0.1
CAMPAIGN_GENERATOR_TEMPERATURE=0.7

# Upload de imagens
MAX_FILE_SIZE_MB=5
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# CORS — origem do frontend em desenvolvimento
CORS_ORIGIN=http://localhost:5173
