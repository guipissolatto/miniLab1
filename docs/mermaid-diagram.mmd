---
config:
  layout: elk
---
flowchart TD
    %% ===================== FRONTEND =====================
    subgraph FRONTEND["Frontend (Web App)"]
      A["Usuário acessa<br/>página HTML estática"]
      B["Insere API Key<br/>(OpenAI ou Claude)"]
      C["Faz upload da imagem<br/>(JPG/PNG)"]
      D["Preenche contexto<br/>(nome, diferencial, tom, público)"]
      E["Seleciona canais<br/>(Instagram, TikTok e/ou Google Ads)"]
      F["Clica em 'Gerar Campanha'"]
    end

    %% ===================== BACKEND =====================
    subgraph BACKEND["Backend / IA Handler"]
      G["Pré-processador de imagem<br/>(tags e atributos visuais)"]
      H["Construtor de prompt<br/>(combina imagem + inputs)"]
      TM["Task Manager<br/>(orquestra chamadas paralelas)"]

      subgraph JSON_DATA["Formato de Dados (JSON)"]
        Z1["Input JSON:<br/>{ canal, prompt, contexto, imagem_url }"]
        Z2["Output JSON:<br/>{ canal, texto_gerado, status, tempo_exec }"]
      end

      I["Executa chamadas à IA<br/>(OpenAI/Claude)"]
      J1["Gerador de Conteúdo<br/>Instagram"]
      J2["Gerador de Conteúdo<br/>TikTok"]
      J3["Gerador de Conteúdo<br/>Google Ads"]
      K["Agregador de resultados<br/>(une outputs JSON)"]
      L["Formatação final para exibição"]
    end

    %% ===================== OUTPUT =====================
    subgraph OUTPUT["Visualização e Copiar"]
      M["Exibe resultados em abas<br/>Instagram · TikTok · Google Ads"]
      N["Botões 'Copiar' individuais"]
      O["Usuário publica nas plataformas"]
    end

    %% ===================== FLUXO =====================
    A --> B --> C --> D --> E --> F --> G --> H --> TM
    TM -->|envia| Z1 -->|usa no prompt| I
    I -->|retorna| Z2 --> TM
    TM -->|distribui JSON| J1 & J2 & J3
    J1 & J2 & J3 --> K --> L --> M --> N --> O

    %% ===================== ESTILOS =====================
    style FRONTEND fill:#eef2ff,stroke:#818cf8
    style BACKEND fill:#fff7ed,stroke:#fb923c
    style OUTPUT fill:#f0fdf4,stroke:#4ade80
    style JSON_DATA fill:#fefce8,stroke:#facc15

    classDef stepBlue fill:#eef2ff,stroke:#818cf8
    classDef stepOrange fill:#fff7ed,stroke:#fb923c
    classDef stepYellow fill:#fefce8,stroke:#facc15
    classDef stepGreen fill:#f0fdf4,stroke:#4ade80

    class A,B,C,D,E,F stepBlue
    class G,H,TM,I,K,L stepOrange
    class Z1,Z2 stepYellow
    class J1,J2,J3 stepYellow
    class M,N,O stepGreen